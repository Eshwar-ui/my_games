## Copy this file to `android/key.properties` (do not commit it) and fill values.
#
# storeFile can be a relative path (from the android/ folder) or an absolute path.
#
# Example:
# storeFile=app/upload-keystore.jks
# storePassword=your_store_password
# keyAlias=upload
# keyPassword=your_key_password

storeFile=app/upload-keystore.jks
storePassword=
keyAlias=upload
keyPassword=
